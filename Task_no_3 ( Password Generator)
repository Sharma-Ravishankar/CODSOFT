import random
import string

print("---------------PASSWORD GENERATOR ----------------")

# taking password length from users
length = int(input("\nEnter the Password length :  "))

# Password creation
result = string.ascii_letters + string.digits + string.punctuation

while True:
    
    password = ""

    for i in range(length):
        password += random.choice(result)

    # Displaying the result
    print("\nGenerated Password:", password)

    choice = input("\nAre you satisfied with the generated password? (yes/no): ").lower()

    if choice != "no":
        print("\nCongratulations You have created a strong password")
        break
